# WebUI bind address. Use 127.0.0.1 behind a reverse proxy, or 0.0.0.0 only with firewall/TLS protection.
MIHOMO_MANAGER_BIND=127.0.0.1

# Host path of this project. Required because the container enters the host namespace for local management.
MIHOMO_MANAGER_HOST_PROJECT_DIR=/opt/mihomo-manager-webui

# Registration behavior: the first user can always register. Set true to allow additional self-registration.
AUTH_ALLOW_REGISTRATION=false

# Session lifetime in hours.
SESSION_TTL_HOURS=24

# Set true when the WebUI is served only through HTTPS.
COOKIE_SECURE=false
