# Bind the WebUI to all interfaces by default. Protect public access with a firewall or HTTPS reverse proxy.
MIHOMO_BIND=0.0.0.0

# Leave these values blank to finish first-run setup in the browser.
# Set them only when you want a preconfigured deployment.
MIHOMO_MODE=
MIHOMO_AUTH=
MIHOMO_HOST=
MIHOMO_SSH_PORT=22
MIHOMO_USER=root

# For Docker Compose remote key mode, set an absolute private-key path on the Docker host
# and start with: docker compose -f docker-compose.yml -f docker-compose.remote-key.yml up -d --build
# If the container manages the Docker host itself, use MIHOMO_HOST=host.docker.internal.
MIHOMO_KEY_PATH=
MIHOMO_PASSWORD=
