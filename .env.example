# WebUI bind address. Use 127.0.0.1 behind a reverse proxy, or 0.0.0.0 only with firewall/TLS protection.
MIHOMO_MANAGER_BIND=127.0.0.1

# Web login. Change these before deployment.
WEBUI_USERNAME=admin
WEBUI_PASSWORD=change-me-to-a-strong-password
WEBUI_SESSION_SECRET=change-me-to-a-long-random-secret
WEBUI_COOKIE_SECURE=false
SESSION_TTL_HOURS=24
AUTH_ALLOW_REGISTRATION=false

# For Docker managing the host, nsenter is required. For direct host Node.js deployment, use direct.
MIHOMO_LOCAL_RUNNER=nsenter
MIHOMO_MANAGER_HOST_PROJECT_DIR=/opt/mihomo-manager-webui
